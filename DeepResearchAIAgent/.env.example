# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Web Search ────────────────────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here

# ── Financial Data ────────────────────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default for dev) — leave as-is
DATABASE_URL=sqlite:///./research_agent.db
# PostgreSQL (prod) — uncomment and fill
# DATABASE_URL=postgresql://user:password@localhost:5432/research_agent

# ── RAG / Vector Store ────────────────────────────────────────────────────────
CHROMA_DB_PATH=./chroma_db

# ── Research Settings ─────────────────────────────────────────────────────────
STANDARD_RESEARCH_DEPTH=10
DEEP_RESEARCH_DEPTH=20
MAX_SEARCH_RESULTS=5

# ── API Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
